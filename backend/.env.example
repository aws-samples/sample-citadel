# Environment for deployment (dev, staging, prod)
ENVIRONMENT=dev

# AWS Account and Region
CDK_DEFAULT_ACCOUNT=your-account-id
CDK_DEFAULT_REGION=ap-southeast-2

# AWS Profile (optional - if you have multiple AWS profiles configured)
# AWS_PROFILE=my-aws-profile

# Admin User Configuration (for initial deployment)
# The admin email can also be passed via: ./deploy.sh --admin-email admin@example.com
ADMIN_EMAIL=admin@example.com
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# Note: The admin password is auto-generated by AWS Secrets Manager during deployment.
# Retrieve it after deployment with:
#   aws secretsmanager get-secret-value --secret-id citadel/admin-password-dev --query SecretString --output text
# The admin user will be:
# - Created in the "Default" organization
# - Added to the "admin" Cognito group
# - Email will be marked as verified
# - Password is temporary — must be changed on first login

# Container build tool (finch or docker)
CDK_DOCKER=finch

# Agent model ID for the intake agent (overrides default in config.py)
AGENT_MODEL=us.anthropic.claude-sonnet-4-6

# Application Host URL (for email templates and frontend)
# This URL will be used in email templates for logo and login links
HOST_URL=https://your-domain.com
