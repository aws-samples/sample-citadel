{
  "name": "backend-layer",
  "version": "1.0.0",
  "description": "Integration APIs and middleware components",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run copy:templates && npm run copy:governance-checklist",
    "copy:templates": "mkdir -p dist/src/cognito-email-templates && cp src/cognito-email-templates/*.html dist/src/cognito-email-templates/",
    "copy:governance-checklist": "mkdir -p dist/lambda && cp src/lambda/governance-checklist.md dist/lambda/governance-checklist.md",
    "build:lambda": "esbuild src/lambda/*.ts src/lambda/seed-blueprints/*.ts src/lambda/seed-model-catalog/*.ts --bundle --platform=node --target=node24 --outdir=dist/lambda --external:@aws-sdk/* --external:snowflake-sdk --external:@databricks/sql --format=cjs && esbuild src/lambda/registry-provisioner.ts src/lambda/agent-config-resolver.ts src/lambda/tool-config-resolver.ts src/lambda/registry-sync.ts src/lambda/integration-resolver.ts src/lambda/gateway-registration-handler.ts src/lambda/registry-agent-record-resolver.ts src/lambda/fabricator-request-resolver.ts src/lambda/reconcile-apps-meta-scheduled-handler.ts src/lambda/model-catalog-sync.ts src/lambda/governance-ui-resolver.ts --bundle --platform=node --target=node24 --outdir=dist/lambda --external:snowflake-sdk --external:@databricks/sql --format=cjs && npm run copy:governance-checklist",
    "watch": "tsc -w",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 1151",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "cdk:synth": "cdk synth",
    "cdk:deploy": "cdk deploy --all",
    "cdk:destroy": "cdk destroy --all",
    "cdk:diff": "cdk diff",
    "deploy": "npm run build && npm run build:lambda && npm run cdk:deploy",
    "deploy:backend": "./scripts/deploy.sh BackendStack",
    "deploy:all": "./scripts/deploy.sh --all",
    "deploy:quick": "npm run build && cdk deploy BackendStack",
    "nag": "cdk synth --all --quiet"
  },
  "dependencies": {
    "@aws-cdk/aws-appsync-alpha": "^2.59.0-alpha.0",
    "@aws-cdk/aws-bedrock-agentcore-alpha": "^2.222.0-alpha.0",
    "@aws-cdk/aws-lambda-python-alpha": "^2.223.0-alpha.0",
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-apigatewayv2": "^3.1016.0",
    "@aws-sdk/client-bedrock": "^3.1075.0",
    "@aws-sdk/client-bedrock-agent": "^3.990.0",
    "@aws-sdk/client-bedrock-agentcore": "^3.400.0",
    "@aws-sdk/client-bedrock-agentcore-control": "^3.1036.0",
    "@aws-sdk/client-cloudwatch": "^3.1037.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1016.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.400.0",
    "@aws-sdk/client-docdb": "^3.1007.0",
    "@aws-sdk/client-dynamodb": "^3.400.0",
    "@aws-sdk/client-ec2": "^3.1075.0",
    "@aws-sdk/client-ecs": "^3.1075.0",
    "@aws-sdk/client-eks": "^3.1075.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.1075.0",
    "@aws-sdk/client-elasticache": "^3.1007.0",
    "@aws-sdk/client-eventbridge": "^3.400.0",
    "@aws-sdk/client-iam": "^3.1007.0",
    "@aws-sdk/client-keyspaces": "^3.1007.0",
    "@aws-sdk/client-lakeformation": "^3.1007.0",
    "@aws-sdk/client-lambda": "^3.400.0",
    "@aws-sdk/client-neptune": "^3.1007.0",
    "@aws-sdk/client-opensearchserverless": "^3.1007.0",
    "@aws-sdk/client-rds": "^3.1007.0",
    "@aws-sdk/client-redshift": "^3.1007.0",
    "@aws-sdk/client-resource-groups-tagging-api": "3.1071.0",
    "@aws-sdk/client-s3": "^3.1070.0",
    "@aws-sdk/client-s3tables": "^3.1007.0",
    "@aws-sdk/client-sagemaker": "^3.1007.0",
    "@aws-sdk/client-secrets-manager": "^3.955.0",
    "@aws-sdk/client-sns": "^3.400.0",
    "@aws-sdk/client-sqs": "^3.932.0",
    "@aws-sdk/client-ssm": "^3.400.0",
    "@aws-sdk/client-sts": "^3.990.0",
    "@aws-sdk/client-timestream-write": "^3.1007.0",
    "@aws-sdk/credential-provider-node": "^3.400.0",
    "@aws-sdk/lib-dynamodb": "^3.400.0",
    "@aws-sdk/s3-request-presigner": "^3.1070.0",
    "@aws-sdk/signature-v4": "^3.300.0",
    "@databricks/sql": "^1.12.0",
    "@smithy/protocol-http": "^3.0.0",
    "ajv": "^6.14.0",
    "aws-cdk-lib": "^2.260.0",
    "aws-lambda": "^1.0.7",
    "constructs": "^10.3.0",
    "jsonwebtoken": "^9.0.2",
    "snowflake-sdk": "^2.3.4",
    "source-map-support": "^0.5.21",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@smithy/util-stream": "^4.5.25",
    "@types/aws-lambda": "^8.10.119",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.19.33",
    "@types/uuid": "^9.0.4",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "aws-cdk": "^2.1128.0",
    "aws-sdk-client-mock": "^4.1.0",
    "cdk-nag": "^2.38.1",
    "esbuild": "^0.25.11",
    "eslint": "^8.47.0",
    "fast-check": "^4.5.3",
    "jest": "^29.6.2",
    "prettier": "^3.0.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
